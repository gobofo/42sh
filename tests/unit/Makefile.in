	-rm -f $(top_builddir)/src/hash_map/$(DEPDIR)/unit_tests-hash_map.Po
	-rm -f $(top_builddir)/src/lexer/$(DEPDIR)/unit_tests-lexer.Po
	-rm -f $(top_builddir)/src/lexer/$(DEPDIR)/unit_tests-lexer_utils.Po
