	-rm -f $(top_builddir)/src/ast/$(DEPDIR)/unit_tests-ast.Po
	-rm -f $(top_builddir)/src/environment/$(DEPDIR)/unit_tests-environment.Po
	-rm -f $(top_builddir)/src/execution/builtins/my_cd/$(DEPDIR)/unit_tests-my_cd.Po
